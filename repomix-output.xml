		});
	});

	afterEach(() => {
		vi.restoreAllMocks();
	});

	describe('initialization', () => {
		it('should initialize GPU resources', async () => {
			await service.initialize();

			expect(global.navigator.gpu.requestAdapter).toHaveBeenCalledWith({
