            viewState: {
              ...state.viewState,
              crosshair: { world_mm: [x, y, z], visible: true }
            }
          }))
        }))
      );
      
      // Act & Assert - Should not throw
      expect(() => {
        noCallbackStore.getState().updateState('test');
      }).not.toThrow();
      
      await new Promise(resolve => setTimeout(resolve, 20));
