      expect(coalesceUtils.hasPendingUpdate()).toBe(true);
      
      // Act
      coalesceUtils.clearPending();
      
      // Assert
      expect(coalesceUtils.hasPendingUpdate()).toBe(false);
      expect(mockBackendCallback).not.toHaveBeenCalled();
