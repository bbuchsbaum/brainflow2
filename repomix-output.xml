        );
        expect(worldFromAxial[0]).toBeCloseTo(crosshairWorld[0], 3);
        expect(worldFromAxial[1]).toBeCloseTo(crosshairWorld[1], 3);
        expect(worldFromAxial[2]).toBeCloseTo(crosshairWorld[2], 3);
      }
    });
  });
