    counts.set(componentName, current + 1);
    
    if (current > 30) {
      console.error(`[RENDER LOOP] ${componentName} has rendered ${current + 1} times!`);
      if (current === 31) {
        console.trace(`First loop detection for ${componentName}`);
      }
    }
  };
}

