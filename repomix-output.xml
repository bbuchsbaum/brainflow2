				unmap: vi.fn()
			}),
			createTexture: vi.fn().mockReturnValue({
				destroy: vi.fn(),
				createView: vi.fn().mockReturnValue({ destroy: vi.fn() })
			}),
			createShaderModule: vi.fn().mockReturnValue({
