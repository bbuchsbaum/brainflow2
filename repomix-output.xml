				resilience: mockBaseHealth,
				offlineMode: true,
				offlineCacheSize: 0,
				sliceFailures: 0
			});
		});

		it('should track slice failures', async () => {
			const error = new Error('Slice load failed');
			error.name = 'NetworkError';

			mockGetSliceData.mockClear().mockRejectedValue(error);

