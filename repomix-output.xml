		// Create fresh mocks
		mockLayerService = {
			getActiveLayers: vi.fn().mockReturnValue([]),
			updateLayer: vi.fn()
		};

		mockAnnotationService = {
			getAnnotationsForSlice: vi.fn().mockReturnValue([]),
