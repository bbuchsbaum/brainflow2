			}),
			createRenderPipeline: vi.fn().mockReturnValue({
				getBindGroupLayout: vi.fn()
			}),
			createCommandEncoder: vi.fn().mockReturnValue({
				beginRenderPass: vi.fn().mockReturnValue({
					setPipeline: vi.fn(),
					setBindGroup: vi.fn(),
					draw: vi.fn(),
					end: vi.fn()
				}),
				copyTextureToBuffer: vi.fn(),
				finish: vi.fn().mockReturnValue({})
			}),
			destroy: vi.fn(),
