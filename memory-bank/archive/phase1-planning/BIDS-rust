#[derive(Debug, Clone, Default)]
pub struct BidsProjectBuilder {
    root_path: PathBuf,
    include_derivatives: bool,
    derivatives_dir: Option<String>,
}

impl BidsProjectBuilder {
    /// Creates a new builder for a BIDS project located at `root_path`.
    pub fn new<P: AsRef<Path>>(root_path: P) -> Self {
        Self {
            root_path: root_path.as_ref().to_path_buf(),
            include_derivatives: false,
            derivatives_dir: None,
        }
    }

    /// Set whether to include the derivatives directory in the scan.
    pub fn include_derivatives(mut self, include: bool) -> Self {
        self.include_derivatives = include;
        self
    }

    /// Specify the relative path to the main derivatives directory (e.g., "derivatives/fmriprep").
    /// If set, `include_derivatives` is automatically enabled.
    pub fn derivatives_dir(mut self, dir: impl Into<String>) -> Self {
        self.derivatives_dir = Some(dir.into());
        self.include_derivatives = true;
        self
    }

    /// Scan the directory structure and build the `BidsProject`.
    pub fn scan(self) -> BidsResult<BidsProject> {
        let canonical_root = fs::canonicalize(&self.root_path)
            .map_err(|e| io_err(&self.root_path, e))?;

        if !canonical_root.is_dir() {
            return Err(BidsError::PathNotFound(self.root_path));
        }
        info!("Initializing BIDS project at: {:?}", canonical_root);

        let participants = read_participants_tsv(&canonical_root)?;
        let description = read_dataset_description(&canonical_root)?;

        info!("Scanning directory structure...");
        let mut has_sessions = false;
        let mut has_derivatives_found = false;

        let prep_dir_prefix_parts: Option<Vec<String>> = self.derivatives_dir
            .as_ref()
            .map(|d| PathBuf::from(d).components().map(|c| c.as_os_str().to_string_lossy().to_string()).collect());

        // --- Directory Walking and Parsing ---
        // Option 1 (Current): Collect paths, then parallel parse
        let file_paths_to_process: Vec<PathBuf> = WalkDir::new(&canonical_root)
            .into_iter()
            .filter_map(Result::ok)
            .filter(|e| e.file_type().is_file())
            .map(|e| e.into_path())
            .collect();

        info!("Found {} potential files. Parsing...", file_paths_to_process.len());

        let all_entities: Vec<FileRow> = file_paths_to_process
            .par_iter()
            .filter_map(|entry_path| {
                let filename = entry_path.file_name()?.to_string_lossy();
                if filename.starts_with('.') { return None; }

                 let relative_path = pathdiff::diff_paths(entry_path, &canonical_root)?;
                 let relative_path_arc = Arc::from(relative_path.to_string_lossy().as_ref());

                let path_components: Vec<&str> = relative_path.components()
                    .map(|c| c.as_os_str().to_str().unwrap_or(""))
                    .collect();

                let mut is_derivative = false;
                 if let Some(prefix_parts) = &prep_dir_prefix_parts {
                     if path_components.len() >= prefix_parts.len() &&
                        path_components[..prefix_parts.len()] == prefix_parts[..] {
                          is_derivative = true;
                      }
                  } else if path_components.first().map_or(false, |&c| c == "derivatives") {
                      is_derivative = true;
                  }

                if is_derivative && !self.include_derivatives { return None; }
                let datatype = get_datatype_from_path(&path_components);
                parse_bids_filename(&filename, relative_path_arc, datatype, is_derivative)
            })
            .collect();
        // End Option 1

        /* // Option 2: Channel + Pool (Conceptual - requires crossbeam_channel)
           use crossbeam_channel::unbounded;
           // ... setup pool ...
           let (sender, receiver) = unbounded::<PathBuf>();
           let canonical_root_clone = canonical_root.clone(); // Clone for thread
           let walk_handle = std::thread::spawn(move || {
               for entry in WalkDir::new(&canonical_root_clone).into_iter().filter_map(Result::ok) {
                   if entry.file_type().is_file() {
                       if sender.send(entry.into_path()).is_err() { break; } // Stop if receiver gone
                   }
               }
           });
           let all_entities: Vec<FileRow> = receiver.into_iter().par_bridge() // Assuming rayon setup
                .filter_map(|entry_path| { /* ... parsing logic ... */ }).collect();
           walk_handle.join().unwrap();
        */ // End Option 2

        info!("Successfully parsed {} BIDS files.", all_entities.len());

        for entity in &all_entities {
            if entity.ses.is_some() { has_sessions = true; }
            if entity.is_derivative { has_derivatives_found = true; }
        }

        if all_entities.is_empty() {
            if description.is_some() || participants.is_some() {
               warn!("Scan did not find any BIDS-parsable files in the dataset.");
            } else {
                return Err(BidsError::ScanError("No BIDS files or metadata found.".to_string()));
            }
        }

        // --- Convert Vec<FileRow> to DataFrame ---
        // Manual construction gives fine-grained control over Arc<str> and Categorical
        let n_rows = all_entities.len();
        let mut filename_builder = Utf8ChunkedBuilder::new("filename", n_rows, n_rows * 20); // Estimate capacity
        let mut rel_path_builder = Utf8ChunkedBuilder::new("relative_path", n_rows, n_rows * 30);
        let mut datatype_builder = PrimitiveChunkedBuilder::<UInt32Type>::new("datatype", n_rows);
        let mut is_deriv_builder = BooleanChunkedBuilder::new("is_derivative", n_rows);
        let mut sub_builder = Utf8ChunkedBuilder::new("sub", n_rows, n_rows * 8);
        let mut ses_builder = Utf8ChunkedBuilder::new("ses", n_rows, n_rows * 8);
        let mut task_builder = Utf8ChunkedBuilder::new("task", n_rows, n_rows * 10);
        let mut run_builder = Utf8ChunkedBuilder::new("run", n_rows, n_rows * 5);
        let mut acq_builder = Utf8ChunkedBuilder::new("acq", n_rows, n_rows * 8);
        let mut ce_builder = Utf8ChunkedBuilder::new("ce", n_rows, n_rows * 8);
        let mut dir_builder = Utf8ChunkedBuilder::new("dir", n_rows, n_rows * 8);
        let mut rec_builder = Utf8ChunkedBuilder::new("rec", n_rows, n_rows * 8);
        let mut mod_builder = Utf8ChunkedBuilder::new("mod_", n_rows, n_rows * 8); // Use mod_
        let mut echo_builder = Utf8ChunkedBuilder::new("echo", n_rows, n_rows * 5);
        let mut space_builder = Utf8ChunkedBuilder::new("space", n_rows, n_rows * 20);
        let mut res_builder = Utf8ChunkedBuilder::new("res", n_rows, n_rows * 8);
        let mut den_builder = Utf8ChunkedBuilder::new("den", n_rows, n_rows * 8);
        let mut label_builder = Utf8ChunkedBuilder::new("label", n_rows, n_rows * 15);
        let mut desc_builder = Utf8ChunkedBuilder::new("desc", n_rows, n_rows * 15);
        let mut sample_builder = Utf8ChunkedBuilder::new("sample", n_rows, n_rows * 8);
        let mut recording_builder = Utf8ChunkedBuilder::new("recording", n_rows, n_rows * 8);
        let mut chunk_builder = Utf8ChunkedBuilder::new("chunk", n_rows, n_rows * 8);
        let mut suffix_builder = Utf8ChunkedBuilder::new("suffix", n_rows, n_rows * 10);
        let mut ext_builder = Utf8ChunkedBuilder::new("extension", n_rows, n_rows * 10);

        let mut cat_map = CategoricalMapBuilder::new();

        for row in all_entities {
            filename_builder.append_value(&row.filename);
            rel_path_builder.append_value(&row.relative_path);
            is_deriv_builder.append_value(row.is_derivative);
            sub_builder.append_option(row.sub.as_deref());
