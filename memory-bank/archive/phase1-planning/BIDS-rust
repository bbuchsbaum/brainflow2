use crate::entities::{BidsDatatype, FileRow}; // No need for get_datatype_from_path here
use once_cell::sync::Lazy;
use regex::Regex;
use log::warn;
use std::sync::Arc;

static BIDS_REGEX: Lazy<Regex> = Lazy::new(|| {
    // Regex remains the same
    Regex::new(
        r"(?x) # Allow comments and whitespace
        ^ # Start of string
        (?:sub-(?P<sub>[a-zA-Z0-9]+))? # Optional sub
        (?:_ses-(?P<ses>[a-zA-Z0-9]+))? # Optional ses
        (?:_sample-(?P<sample>[a-zA-Z0-9]+))? # Optional sample (BIDS 2.0)
        (?:_task-(?P<task>[a-zA-Z0-9]+))? # Optional task
        (?:_acq-(?P<acq>[a-zA-Z0-9]+))? # Optional acq
        (?:_ce-(?P<ce>[a-zA-Z0-9]+))? # Optional ce
        (?:_dir-(?P<dir>[a-zA-Z0-9]+))? # Optional dir
        (?:_rec-(?P<rec>[a-zA-Z0-9]+))? # Optional rec
        (?:_recording-(?P<recording>[a-zA-Z0-9]+))? # Optional recording (BIDS 2.0)
        (?:_run-(?P<run>[a-zA-Z0-9]+))? # Optional run
        (?:_mod-(?P<mod>[a-zA-Z0-9]+))? # Optional mod
        (?:_echo-(?P<echo>[a-zA-Z0-9]+))? # Optional echo
        (?:_chunk-(?P<chunk>[a-zA-Z0-9]+))? # Optional chunk (BIDS 2.0)
        (?:_space-(?P<space>[a-zA-Z0-9]+))? # Optional space (derivatives)
        (?:_res-(?P<res>[a-zA-Z0-9]+))? # Optional res (derivatives)
        (?:_den-(?P<den>[a-zA-Z0-9]+))? # Optional den (derivatives)
        (?:_label-(?P<label>[a-zA-Z0-9]+))? # Optional label (derivatives)
        (?:_desc-(?P<desc>[a-zA-Z0-9]+))? # Optional desc (derivatives)
        _ # The separator before the suffix
        (?P<suffix>[a-zA-Z0-9]+) # The main suffix/modality
        (?P<extension>\..+) # The file extension(s) - MUST start with dot, allow multiple dots
        $ # End of string
        "
    ).expect("Failed to compile BIDS regex")
});

/// Parses a BIDS filename and populates a FileRow struct. Internal function.
pub(crate) fn parse_bids_filename(
    filename: &str,
    relative_path: Arc<str>,
    datatype: Option<BidsDatatype>,
    is_derivative: bool,
) -> Option<FileRow> {
    BIDS_REGEX.captures(filename).and_then(|caps| {
        let get_capture = |name: &str| caps.name(name).map(|m| Arc::from(m.as_str()));

        let sub = get_capture("sub");
        let suffix = get_capture("suffix");
        let extension = get_capture("extension");

        if filename.starts_with("sub-") && sub.is_none() {
             warn!("Filename '{}' starts with 'sub-' but failed to parse subject.", filename);
             return None;
        }
        if suffix.is_none() || extension.is_none() {
             warn!("Filename '{}' failed to parse suffix or extension.", filename);
             return None;
        }

        Some(FileRow {
            filename: Arc::from(filename),
            relative_path,
            datatype,
            is_derivative,
            sub,
            ses: get_capture("ses"),
            task: get_capture("task"),
            acq: get_capture("acq"),
            ce: get_capture("ce"),
            dir: get_capture("dir"),
            rec: get_capture("rec"),
            run: get_capture("run"),
            mod_: get_capture("mod"),
            echo: get_capture("echo"),
            space: get_capture("space"),
            res: get_capture("res"),
            den: get_capture("den"),
            label: get_capture("label"),
            desc: get_capture("desc"),
            sample: get_capture("sample"),
            recording: get_capture("recording"),
            chunk: get_capture("chunk"),
            suffix,
            extension,
        })
    })
}
