use std::path::PathBuf;
use thiserror::Error;

#[derive(Error, Debug)]
pub enum BidsError {
    #[error("IO Error accessing '{path}': {source}")]
    Io {
        path: PathBuf,
        #[source]
        source: std::io::Error,
    },

    #[error("Polars Error: {0}")]
    Polars(#[from] polars::prelude::PolarsError),

    #[error("JSON Error reading '{path}': {source}")]
    Json {
        path: PathBuf,
        #[source]
        source: serde_json::Error,
    },

    #[error("Path not found or is not a directory: {0}")]
    PathNotFound(PathBuf),

    #[error("Missing required BIDS file at root: {0}")]
    MissingRootFile(String),

    #[error("Failed to parse BIDS filename: {0}")]
    ParseFilenameError(String),

    #[error("Directory scanning failed: {0}")]
    ScanError(String),

    #[error("Invalid BIDS query filter: {0}")]
    InvalidFilter(String),

    // Unified NotFound error
    #[error("No {kind} files matched query: {query_summary}")]
    NotFound {
        kind: &'static str,
        query_summary: String,
    },

    #[error("Feature not implemented: {0}")]
    NotImplemented(String),

    #[error("Could not determine relative path for: {0}")]
    RelativePathError(PathBuf),

    #[error("Error building project: {0}")]
    BuilderError(String),

    #[error("Categorical encoding error for datatype: {0}")]
    CategoricalError(String),
}

pub type BidsResult<T> = Result<T, BidsError>;

// Helper to wrap IO errors with context
pub(crate) fn io_err<P: AsRef<std::path::Path>>(path: P, source: std::io::Error) -> BidsError {
    BidsError::Io { path: path.as_ref().to_path_buf(), source }
}

// Helper to wrap JSON errors with context
pub(crate) fn json_err<P: AsRef<std::path::Path>>(path: P, source: serde_json::Error) -> BidsError {
    BidsError::Json { path: path.as_ref().to_path_buf(), source }
}
