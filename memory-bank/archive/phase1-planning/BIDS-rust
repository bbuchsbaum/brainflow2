// Public Query Trait (Opaque Type)
pub trait QueryDsl<'a>: Sized { // Add Sized bound here
    // --- Filter Methods ---
    fn sub(self, value: impl Into<Arc<str>>) -> Self;
    fn ses(self, value: impl Into<Arc<str>>) -> Self;
    fn task(self, value: impl Into<Arc<str>>) -> Self;
    fn run(self, value: impl Into<Arc<str>>) -> Self;
    fn suffix(self, value: impl Into<Arc<str>>) -> Self;
    fn acq(self, value: impl Into<Arc<str>>) -> Self;
    fn space(self, value: impl Into<Arc<str>>) -> Self;
    fn desc(self, value: impl Into<Arc<str>>) -> Self;
    fn extension(self, value: impl Into<Arc<str>>) -> Self;
    fn datatype(self, value: BidsDatatype) -> Self;
    // TODO: Regex variants .sub_matches(), etc.
    // TODO: Composable variants .any_of(), .not()

    // --- Derivative Status ---
    fn raw_only(self) -> Self;
    fn derivatives_only(self) -> Self;

    // --- Configuration ---
    fn strict(self, strict: bool) -> Self;

    // --- Terminal Methods ---
    fn dataframe(self) -> BidsResult<DataFrame>;
    fn relative_paths(self) -> BidsResult<Vec<Arc<str>>>;
    fn absolute_paths(self) -> BidsResult<Vec<PathBuf>>;
    fn first_relative_path(self) -> BidsResult<Option<Arc<str>>>;
    fn first_absolute_path(self) -> BidsResult<Option<PathBuf>>;
    fn count(self) -> BidsResult<usize>;
}

// Internal Query Builder Implementation
#[derive(Clone, Debug)]
pub(crate) struct QueryBuilderInternal<'a> {
    project: &'a BidsProject,
    filters: HashMap<String, Expr>,
    target_derivative_status: Option<bool>,
    strict: bool, // Default is now false
}

impl<'a> QueryBuilderInternal<'a> {
    pub(crate) fn new(project: &'a BidsProject) -> Self {
        Self {
            project,
            filters: HashMap::new(),
            target_derivative_status: None,
            strict: false, // Default to lenient matching (like pybids)
        }
    }

    fn add_filter_expr(mut self, column: &str, expr: Expr) -> Self {
        self.filters.insert(column.to_string(), expr);
        self
    }

    fn add_eq_filter(mut self, column: &str, value: Arc<str>) -> Self {
        let filter_expr = col(column).eq(lit(value.to_string())); // Use owned string for literal

        let condition = if !self.strict {
            col(column).is_null().or(filter_expr) // Match null OR equal
        } else {
            filter_expr // Strict: Must be equal (implicitly filters nulls)
        };
        self.filters.insert(column.to_string(), condition);
        self
    }

    fn execute_query(self) -> LazyFrame {
        let mut lazy_df = self.project.files().clone().lazy();

        if let Some(is_deriv) = self.target_derivative_status {
            lazy_df = lazy_df.filter(col("is_derivative").eq(lit(is_deriv)));
        }

        if !self.filters.is_empty() {
            let schema = lazy_df.schema().unwrap_or_default();
            let mut combined_expr: Option<Expr> = None;

            for (col_name, expr) in self.filters {
                if schema.get(&col_name).is_none() {
                    if self.strict {
                        combined_expr = Some(lit(false));
                        break;
                    } else {
                        // If column is missing and not strict, this filter has no effect
                        continue;
                    }
                }

                if let Some(existing) = combined_expr {
                    combined_expr = Some(existing.and(expr));
                } else {
                    combined_expr = Some(expr);
                }
            }

            if let Some(final_expr) = combined_expr {
                lazy_df = lazy_df.filter(final_expr);
            }
        }
        lazy_df
    }
}

// Implement the Public Trait for the Internal Builder
impl<'a> QueryDsl<'a> for QueryBuilderInternal<'a> {
    fn sub(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("sub", value.into()) }
    fn ses(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("ses", value.into()) }
    fn task(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("task", value.into()) }
    fn run(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("run", value.into()) }
    fn suffix(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("suffix", value.into()) }
    fn acq(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("acq", value.into()) }
    fn space(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("space", value.into()) }
    fn desc(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("desc", value.into()) }
    fn extension(self, value: impl Into<Arc<str>>) -> Self { self.add_eq_filter("extension", value.into()) }

    fn datatype(self, value: BidsDatatype) -> Self {
        // TODO: Cache the categorical -> physical index map in BidsProject for performance
        let cat_dtype = self.project.files().schema().get_field("datatype")
            .map(|f| f.dtype().clone())
            .filter(|dt| matches!(dt, DataType::Categorical(..)));

        let expr = if let Some(DataType::Categorical(Some(rev_map), _)) = cat_dtype {
            if let Some(idx) = rev_map.find(value.as_ref()) {
                col("datatype").eq(lit(idx)) // Compare physical representation
            } else {
                 lit(false) // Value not present in this dataset's categories
            }
        } else {
            warn!("Datatype column is not categorical or not found. Datatype filter ignored.");
            lit(true) // Don't filter if column isn't usable
        };
        self.add_filter_expr("datatype", expr)
    }

    fn raw_only(mut self) -> Self { self.target_derivative_status = Some(false); self }
    fn derivatives_only(mut self) -> Self { self.target_derivative_status = Some(true); self }
    fn strict(mut self, strict: bool) -> Self { self.strict = strict; self }

    // --- Terminal Methods ---
    fn dataframe(self) -> BidsResult<DataFrame> { self.execute_query().collect().map_err(BidsError::Polars) }

    fn relative_paths(self) -> BidsResult<Vec<Arc<str>>> {
        let df = self.execute_query().select(&[col("relative_path")]).collect()?;
        df.column("relative_path")?.utf8()?
            .into_iter()
            .filter_map(|opt_s| opt_s.map(Arc::from))
            .collect::<Vec<_>>()
            .pipe(Ok)
    }

    fn absolute_paths(self) -> BidsResult<Vec<PathBuf>> {
        let root = self.project.root_path().to_path_buf();
        let df = self.execute_query().select(&[col("relative_path")]).collect()?;
        df.column("relative_path")?.utf8()?
            .into_iter()
            .filter_map(|opt_s| opt_s.map(|s| root.join(s)))
            .collect::<Vec<_>>()
            .pipe(Ok)
    }

    fn first_relative_path(self) -> BidsResult<Option<Arc<str>>> {
        let df = self.execute_query().select(&[col("relative_path")]).first().collect()?;
        if df.height() == 0 { Ok(None) }
        else { Ok(df.column("relative_path")?.utf8()?.get(0).map(Arc::from)) }
    }

    fn first_absolute_path(self) -> BidsResult<Option<PathBuf>> {
        let root = self.project.root_path().to_path_buf();
        let df = self.execute_query().select(&[col("relative_path")]).first().collect()?;
        if df.height() == 0 { Ok(None) }
        else { Ok(df.column("relative_path")?.utf8()?.get(0).map(|s| root.join(s))) }
    }

    fn count(self) -> BidsResult<usize> {
        let df = self.execute_query()
             .select(&[len().alias("count")]) // Use Polars `len()` expression
             .collect()?;
        df.column("count")?
             .get(0)?
             .try_extract::<u32>() // len() returns u32
             .map(|v| v as usize)
             .map_err(|_| PolarsError::ComputeError("Failed to extract count".into()).into())
    }
}
