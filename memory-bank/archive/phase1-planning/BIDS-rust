            } else {
                datatype_builder.append_null();
            }
        }

        let rev_map = Arc::new(cat_map.finish());

        // Create Series from builders
        let filename_series = filename_builder.finish().into_series();
        let rel_path_series = rel_path_builder.finish().into_series();
        let datatype_cat_series = datatype_builder.finish().into_series()
            .cast(&DataType::Categorical(Some(rev_map), CategoricalOrdering::Physical))?;
        let is_deriv_series = is_deriv_builder.finish().into_series();
        let sub_series = sub_builder.finish().into_series();
        let ses_series = ses_builder.finish().into_series();
        let task_series = task_builder.finish().into_series();
        let run_series = run_builder.finish().into_series();
        let acq_series = acq_builder.finish().into_series();
        let ce_series = ce_builder.finish().into_series();
        let dir_series = dir_builder.finish().into_series();
        let rec_series = rec_builder.finish().into_series();
        let mod_series = mod_builder.finish().into_series(); // Renamed field
        let echo_series = echo_builder.finish().into_series();
        let space_series = space_builder.finish().into_series();
        let res_series = res_builder.finish().into_series();
        let den_series = den_builder.finish().into_series();
        let label_series = label_builder.finish().into_series();
        let desc_series = desc_builder.finish().into_series();
        let sample_series = sample_builder.finish().into_series();
        let recording_series = recording_builder.finish().into_series();
        let chunk_series = chunk_builder.finish().into_series();
        let suffix_series = suffix_builder.finish().into_series();
        let ext_series = ext_builder.finish().into_series();

        // Assemble DataFrame
        let files_df = DataFrame::new(vec![
             filename_series, rel_path_series, datatype_cat_series, is_deriv_series,
             sub_series, ses_series, task_series, acq_series, ce_series, dir_series,
             rec_series, run_series, mod_series, echo_series, space_series, res_series,
             den_series, label_series, desc_series, sample_series, recording_series,
             chunk_series, suffix_series, ext_series
        ])?;

        debug!("Created DataFrame with {} rows and {} columns.", files_df.height(), files_df.width());

        Ok(BidsProject {
            root_path: canonical_root,
            participants,
            description,
            files: files_df,
            has_sessions,
            has_derivatives: has_derivatives_found,
            prep_dir_pattern: self.derivatives_dir,
            cached_subjects: OnceCell::new(),
            cached_sessions: OnceCell::new(),
            cached_tasks: OnceCell::new(),
        })
    }
}
