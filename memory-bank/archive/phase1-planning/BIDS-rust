use crate::io;
use polars::prelude::*;
use polars::frame::row::Row; // For RowIter type
use serde_json;
use std::path::{Path, PathBuf};
use std::sync::Arc;
use once_cell::sync::OnceCell;
use crate::_internal::Pipe; // Use internal Pipe trait


#[derive(Debug)]
pub struct BidsProject {
    #[allow(dead_code)] // Used internally by methods
    pub(crate) root_path: PathBuf,
    #[allow(dead_code)]
    pub(crate) participants: Option<DataFrame>,
    #[allow(dead_code)]
    pub(crate) description: Option<serde_json::Value>,
    #[allow(dead_code)]
    pub(crate) files: DataFrame,
    #[allow(dead_code)]
    pub(crate) has_sessions: bool,
    #[allow(dead_code)]
    pub(crate) has_derivatives: bool,
    #[allow(dead_code)]
    pub(crate) prep_dir_pattern: Option<String>,
    // Caches
    pub(crate) cached_subjects: OnceCell<Vec<Arc<str>>>,
    pub(crate) cached_sessions: OnceCell<Vec<Arc<str>>>,
    pub(crate) cached_tasks: OnceCell<Vec<Arc<str>>>,
    // TODO: Cache categorical map for datatype
}

impl BidsProject {
    /// Creates a new `BidsProjectBuilder` to configure and scan a BIDS dataset.
    pub fn builder<P: AsRef<Path>>(root_path: P) -> BidsProjectBuilder {
        BidsProjectBuilder::new(root_path)
    }

    /// Convenience function to open and scan a BIDS dataset with default options.
    pub fn open<P: AsRef<Path>>(root_path: P) -> BidsResult<Self> {
        BidsProjectBuilder::new(root_path).scan()
    }

    // --- Accessors ---
    pub fn root_path(&self) -> &Path { &self.root_path }
    pub fn participants_table(&self) -> Option<&DataFrame> { self.participants.as_ref() }
    pub fn dataset_description(&self) -> Option<&serde_json::Value> { self.description.as_ref() }
    pub fn files_df(&self) -> &DataFrame { &self.files }
    pub fn has_sessions(&self) -> bool { self.has_sessions }
    pub fn has_derivatives(&self) -> bool { self.has_derivatives }

    /// Returns a sorted list of unique participant IDs found (without "sub-" prefix).
    pub fn participants(&self) -> BidsResult<&Vec<Arc<str>>> {
        self.cached_subjects
            .get_or_try_init(|| self.fetch_unique_entities("sub", Some("sub-")))
    }

    /// Returns a sorted list of unique session IDs found (without "ses-" prefix), or `None`.
    pub fn sessions(&self) -> BidsResult<Option<&Vec<Arc<str>>>> {
        if !self.has_sessions { return Ok(None); }
        self.cached_sessions
            .get_or_try_init(|| self.fetch_unique_entities("ses", Some("ses-")))
            .map(Some)
    }

    /// Returns a sorted list of unique task names found (without "task-" prefix).
    pub fn tasks(&self) -> BidsResult<&Vec<Arc<str>>> {
        self.cached_tasks
            .get_or_try_init(|| self.fetch_unique_entities("task", Some("task-")))
    }

    // --- Query Builder Access ---

    /// Start building a query to find files within the dataset.
    pub fn filter(&self) -> impl QueryDsl {
        QueryBuilderInternal::new(self)
    }

    // --- Convenience Query Methods ---

    /// Find functional scans (e.g., bold NIfTI). Returns absolute paths.
    pub fn func_scans(
        &self,
        sub: Option<&str>,
        ses: Option<&str>,
        task: Option<&str>,
        run: Option<&str>,
    ) -> BidsResult<Vec<PathBuf>> {
        let mut query = self.filter()
            // .suffix("(bold|cbv)") // Needs regex
            .suffix("bold")
            // .extension(".(nii|nii.gz)") // Needs regex
             .extension(".nii.gz")
            .raw_only();

        if let Some(s) = sub { query = query.sub(s); }
        if let Some(s) = ses { query = query.ses(s); }
        if let Some(t) = task { query = query.task(t); }
        if let Some(r) = run { query = query.run(r); }
        query.absolute_paths()
    }

    /// Find event files (.tsv). Returns absolute paths.
    pub fn event_files(
        &self,
        sub: Option<&str>,
        ses: Option<&str>,
        task: Option<&str>,
        run: Option<&str>,
    ) -> BidsResult<Vec<PathBuf>> {
        let mut query = self.filter()
            .datatype(crate::entities::BidsDatatype::Func)
            .suffix("events")
            .extension(".tsv")
            .raw_only();

        if let Some(s) = sub { query = query.sub(s); }
        if let Some(s) = ses { query = query.ses(s); }
        if let Some(t) = task { query = query.task(t); }
        if let Some(r) = run { query = query.run(r); }
        query.absolute_paths()
    }

    /// Find preprocessed scans. Returns absolute paths.
    pub fn preproc_scans(
        &self,
        sub: Option<&str>,
        ses: Option<&str>,
        task: Option<&str>,
        run: Option<&str>,
        space: Option<&str>,
        desc: Option<&str>,
        suffix: Option<&str>,
        extension: Option<&str>,
    ) -> BidsResult<Vec<PathBuf>> {
        let mut query = self.filter().derivatives_only();
        if let Some(s) = sub { query = query.sub(s); }
        if let Some(s) = ses { query = query.ses(s); }
        if let Some(t) = task { query = query.task(t); }
        if let Some(r) = run { query = query.run(r); }
        if let Some(s) = space { query = query.space(s); }
        if let Some(d) = desc { query = query.desc(d); }
        if let Some(suf) = suffix { query = query.suffix(suf); }
        if let Some(ext) = extension { query = query.extension(ext); }
        query.absolute_paths()
    }

    // --- Data Reading Methods ---

    /// Reads matching event files into a single Polars DataFrame.
    pub fn read_events(
        &self,
        sub: Option<&str>,
        ses: Option<&str>,
        task: Option<&str>,
        run: Option<&str>,
    ) -> BidsResult<DataFrame> {
        let event_file_paths = self.event_files(sub, ses, task, run)?;
        let query_summary = format!("sub={:?}, ses={:?}, task={:?}, run={:?}", sub, ses, task, run);
        if event_file_paths.is_empty() {
            return Err(BidsError::NotFound { kind: "event", query_summary });
        }
        io::scan_and_concat_tsvs(
            &event_file_paths, &self.files, &self.root_path, "event",
            Some(NullValues::AllColumns(vec!["n/a".to_string(), "NA".to_string()])),
        )
    }

    /// Reads matching confound files into a single Polars DataFrame.
    pub fn read_confounds(
        &self,
        sub: Option<&str>,
        ses: Option<&str>,
        task: Option<&str>,
        run: Option<&str>,
    ) -> BidsResult<DataFrame> {
        if !self.has_derivatives {
            return Err(BidsError::NotFound {
                kind: "confound", query_summary: "Project has no derivatives".to_string()
            });
        }
        let mut query = self.filter()
            // .suffix("(confounds|regressors|timeseries)") // Needs regex
            .suffix("timeseries") // Temp
            .extension(".tsv").derivatives_only();

        if let Some(s) = sub { query = query.sub(s); }
        if let Some(s) = ses { query = query.ses(s); }
        if let Some(t) = task { query = query.task(t); }
        if let Some(r) = run { query = query.run(r); }

        let confound_file_paths = query.absolute_paths()?;
        let query_summary = format!("sub={:?}, ses={:?}, task={:?}, run={:?} (suffix=timeseries, ext=.tsv)", sub, ses, task, run);
        if confound_file_paths.is_empty() {
            return Err(BidsError::NotFound { kind: "confound", query_summary });
        }
        io::scan_and_concat_tsvs(
            &confound_file_paths, &self.files, &self.root_path, "confound",
            Some(NullValues::AllColumns(vec!["n/a".to_string(), "NA".to_string()])),
        )
    }

    // --- Internal Helper ---
    fn fetch_unique_entities(&self, column_name: &str, prefix_to_strip: Option<&str>) -> BidsResult<Vec<Arc<str>>> {
        if self.files.height() == 0 { return Ok(Vec::new()); }
        let column = self.files.column(column_name)?;
        let unique_series = column.unique()?.sort(false)?;

        let entities: Vec<Arc<str>> = unique_series.utf8()?
            .into_iter()
            .filter_map(|opt_s| opt_s.map(|s| {
                let final_s = prefix_to_strip.and_then(|prefix| s.strip_prefix(prefix)).unwrap_or(s);
                Arc::from(final_s)
            }))
            .collect();
        Ok(entities)
    }
}

