use crate::error::{BidsError, BidsResult, io_err, json_err};
use crate::entities::FileRow; // Now needed for metadata type
use polars::prelude::*;
use std::fs::File;
use std::path::{Path, PathBuf};
use std::io::BufReader;
use std::sync::Arc;
use log::{info, warn};

/// Reads the participants.tsv file.
pub(crate) fn read_participants_tsv(root_path: &Path) -> BidsResult<Option<DataFrame>> {
    let tsv_path = root_path.join("participants.tsv");
    if !tsv_path.exists() {
        return Err(BidsError::MissingRootFile("participants.tsv".to_string()));
    }
    info!("Reading participants file: {:?}", tsv_path);

    let mut schema = Schema::new();
    schema.with_column("participant_id".to_string(), DataType::Utf8);

    let lazy_df = LazyCsvReader::new(&tsv_path)
        .with_separator(b'\t')
        .has_header(true)
        .with_dtypes(Some(Arc::new(schema)))
        .with_ignore_errors(true)
        .finish()?;

    let df = lazy_df.collect()?;
    Ok(Some(df))
}

/// Reads the dataset_description.json file.
pub(crate) fn read_dataset_description(root_path: &Path) -> BidsResult<Option<serde_json::Value>> {
    let json_path = root_path.join("dataset_description.json");
    if !json_path.exists() {
        warn!("dataset_description.json not found at {:?}", root_path);
        return Ok(None);
    }
    info!("Reading dataset description: {:?}", json_path);
    let file = File::open(&json_path).map_err(|e| io_err(&json_path, e))?;
    let reader = BufReader::new(file);
    let description = serde_json::from_reader(reader).map_err(|e| json_err(&json_path, e))?;
    Ok(Some(description))
}

/// Lazily scans multiple TSV files (events, confounds) and concatenates them.
/// Adds metadata columns based on the main project DataFrame.
pub(crate) fn scan_and_concat_tsvs(
    paths: &[PathBuf],
    main_df: &DataFrame,
    root_path: &Path,
    file_type_name: &str,
    null_values: Option<NullValues>,
) -> BidsResult<DataFrame> {
    if paths.is_empty() {
        return Ok(DataFrame::default());
    }

    let mut lazy_frames: Vec<LazyFrame> = Vec::with_capacity(paths.len());
    let metadata_cols = ["sub", "ses", "task", "run"];

    let relative_paths_to_find: Vec<Result<String, BidsError>> = paths.iter().map(|path| {
        pathdiff::diff_paths(path, root_path)
            .map(|p| p.to_string_lossy().to_string())
            .ok_or_else(|| BidsError::RelativePathError(path.clone()))
    }).collect();

    let relative_paths: Vec<String> = relative_paths_to_find.into_iter().collect::<Result<_, _>>()?;

    let relevant_meta_df = main_df.clone().lazy()
        .filter(col("relative_path").is_in(lit(Series::new("paths", &relative_paths))))
        .select([col("relative_path")].into_iter().chain(metadata_cols.iter().map(|&c| col(c))))
        .collect()?;


    for (i, path) in paths.iter().enumerate() {
        info!("Scanning {} file: {:?}", file_type_name, path);
        let current_relative_path = &relative_paths[i];

        let mut lf = LazyCsvReader::new(path)
            .with_separator(b'\t')
            .has_header(true)
            .with_null_values(null_values.clone())
            .with_ignore_errors(true)
            .finish()?;

        let meta_row = relevant_meta_df.clone().lazy()
             .filter(col("relative_path").eq(lit(current_relative_path)))
             .first()
             .collect()?;

        if meta_row.height() == 1 {
            for &col_name in &metadata_cols {
                if lf.schema()?.get(col_name).is_none() {
                    if let Ok(series) = meta_row.column(col_name) {
                        if let Ok(scalar_value) = series.get(0) {
                             let literal_value = match scalar_value {
                                AnyValue::Utf8(s) => AnyValue::Utf8Owned(s.to_string()), // Use owned string for literal
                                _ => scalar_value
                             };
                            lf = lf.with_column(lit(literal_value).alias(col_name));
                        } else {
                             warn!("Could not get scalar value for metadata '{}' from file {}", col_name, current_relative_path);
                             lf = lf.with_column(lit(NULL).cast(DataType::Utf8).alias(col_name));
                        }
                    } else {
                         warn!("Metadata column '{}' not found in main DF for file {}", col_name, current_relative_path);
                         lf = lf.with_column(lit(NULL).cast(DataType::Utf8).alias(col_name));
                    }
                }
            }
        } else {
            warn!("Could not find unique metadata in main DataFrame for {} file: {}", file_type_name, current_relative_path);
            for &col_name in &metadata_cols {
                if lf.schema()?.get(col_name).is_none() {
                    lf = lf.with_column(lit(NULL).cast(DataType::Utf8).alias(col_name));
                }
            }
        }

        lazy_frames.push(lf);
    }

    // TODO: Add warning/error if schemas are incompatible during concat?
    // `UnionArgs::default()` might handle some mismatches by upcasting types.
    concat_impl(&lazy_frames, UnionArgs::default())
        .map_err(BidsError::Polars)?
        .collect()
        .map_err(BidsError::Polars)
}
