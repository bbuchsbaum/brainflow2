{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "Brainflow",
  "version": "0.1.0",
  "identifier": "com.brainflow.dev",

  "build": {
    "beforeDevCommand": "cd /Users/bbuchsbaum/code/brainflow2/ui2 && npm run dev",
    "beforeBuildCommand": "cd /Users/bbuchsbaum/code/brainflow2/ui2 && npm run build",
    "frontendDist": "../ui2/dist",
    "devUrl": "http://localhost:5174"
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Brainflow",
        "width": 1320,
        "height": 880,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default",
        "api-bridge"
      ]
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
} 
