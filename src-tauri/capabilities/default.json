{
    "$schema": "../gen/schemas/desktop-schema.json",
  
    "identifier": "default",
    "description": "Default capability for the main window",
    "windows": ["main"],
  
    "permissions": [
      
      "core:default",
      "core:event:allow-listen",
      "core:event:allow-emit",
      "core:menu:default",
  

      "dialog:default",
      
      "api-bridge:default",
  
     
      {
        "identifier": "fs:read-files",
        "allow": [
          { "path": "$DOWNLOAD/*"  },   
          { "path": "$DOWNLOAD/**/*"},
          { "path": "$HOME/*" },
          { "path": "$HOME/**/*" },
          { "path": "$DOCUMENT/*" },
          { "path": "$DOCUMENT/**/*" },
          { "path": "$DESKTOP/*" },
          { "path": "$DESKTOP/**/*" }
        ]
      }
    ]
  }