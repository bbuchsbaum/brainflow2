			<div class="panel">
				<div class="panel-header">File Browser</div>
				<div class="panel-content">
					<!-- <MountableTreeBrowser /> -->
					<div style="padding: 20px;">File browser will go here</div>
				</div>
			</div>
		</div>
		
		<!-- Center content -->
		<div class="center-content">
			<div class="panel">
				<div class="panel-header">Volume View</div>
				<div class="panel-content">
					<VolumeView />
				</div>
			</div>
		</div>
		
		<!-- Right sidebar -->
		<div class="sidebar">
			<div class="panel">
				<div class="panel-header">Layers</div>
				<div class="panel-content">
					<!-- <LayerPanel /> -->
					<div style="padding: 20px;">Layer controls will go here</div>
				</div>
			</div>
		</div>
	</div>
	
	<!-- Hidden children for routing -->
	<div style="display: none;">
		{@render children()}
	</div>
	
	<StatusBar />
</div>

