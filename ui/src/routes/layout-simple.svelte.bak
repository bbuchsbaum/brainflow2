<script lang="ts">
	import { onMount } from 'svelte';
	
	// Bootstrap config validation - BEFORE any service initialization
	import { loadAndValidateConfig } from '$lib/validation/schemas/Config';
	import { getContainer } from '$lib/di/Container';
	
	// Import components directly
	import MountableTreeBrowser from '$lib/components/MountableTreeBrowser.svelte';
	import TestPanel from '$lib/components/TestPanel.svelte';
	
	let { children } = $props();
	
	onMount(async () => {
		try {
			// Bootstrap config validation
			const validatedConfig = loadAndValidateConfig();
			
			// Store validated config globally before initializing DI container
			(globalThis as any).__BRAINFLOW_VALIDATED_CONFIG__ = validatedConfig;
			
			// Initialize DI container with validated config
			const container = getContainer();
			
			// Attach default event listeners after container is ready
			const eventBus = await container.resolve('eventBus');
			const { attachDefaultListeners } = await import('$lib/events/EventBus');
			await attachDefaultListeners(eventBus, container);
			
			// Initialize StoreServiceBridge
			console.log('[+layout] Initializing StoreServiceBridge...');
			const storeServiceBridge = await container.resolve('storeServiceBridge');
			await storeServiceBridge.init();
			console.log('[+layout] StoreServiceBridge initialized');
		} catch (err) {
			console.error('Bootstrap failed:', err);
		}
	});
</script>

<!-- Simple manual layout for testing -->
<div class="app-container">
	<div class="sidebar">
		<MountableTreeBrowser />
	</div>
	
	<div class="main-content">
		<div class="main-panel">
			<TestPanel title="Main View" />
		</div>
		
		<div class="right-panels">
			<div class="panel">
				<TestPanel title="Layers" />
			</div>
			<div class="panel">
				<TestPanel title="Layer Controls" />
			</div>
			<div class="panel">
				<TestPanel title="Plots" />
			</div>
		</div>
	</div>
	
	{@render children()}
</div>

<style>
	.app-container {
		display: flex;
		width: 100vw;
		height: 100vh;
		background: #0a0a0a;
		color: white;
		overflow: hidden;
	}
	
	.sidebar {
		width: 300px;
		min-width: 200px;
		height: 100%;
		background: #1a1a1a;
		border-right: 1px solid #333;
		overflow: auto;
	}
	
	.main-content {
		flex: 1;
		display: flex;
		height: 100%;
		overflow: hidden;
	}
	
	.main-panel {
		flex: 1;
		background: #2a2a2a;
		border: 1px solid #333;
		margin: 4px;
		overflow: auto;
	}
	
	.right-panels {
		width: 300px;
		display: flex;
		flex-direction: column;
		gap: 4px;
		padding: 4px;
	}
	
	.panel {
		flex: 1;
		background: #2a2a2a;
		border: 1px solid #333;
		overflow: auto;
	}
</style>