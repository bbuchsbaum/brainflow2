    let volume_store = Arc::new(IntegrationVolumeStore::with_standard_volumes()
        .expect("Failed to create test volumes"));
    
    let cpu_slicer = CpuSlicer::new(volume_store.clone());
    
    use std::f32::consts::PI;
    
