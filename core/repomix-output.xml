            render_service.update_layer_stack(&[layer], &[(10, 10, 10)], &[transform]);
            render_service.update_frame_params(
                [0.0, 0.0, 0.0, 1.0], // Origin at center
                u_vec,
                v_vec,
                [100, 100],
