    let harness = HarnessBuilder::new()
        .with_cpu_provider(cpu_provider)
        .with_gpu_provider(gpu_provider)
        .with_tolerance(0, 0.0) // Expect exact match for CPU vs CPU
        .build()
        .expect("Failed to create harness");
    
    // Test basic axial slices
