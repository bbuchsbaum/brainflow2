        let space = NeuroSpace::new(
            vec![10, 10, 10],
            Some(vec![1.0, 1.0, 1.0]),
            None,
            None,
            None,
        ).expect("Failed to create NeuroSpace");
        
        assert_eq!(space.dim, vec![10, 10, 10]);
    }
