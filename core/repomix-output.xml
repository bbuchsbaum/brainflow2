    pub fn new(output_dir: String) -> Self {
        let images_dir = format!("{}/images", output_dir);
        fs::create_dir_all(&images_dir).unwrap();
        
        Self { 
            output_dir: output_dir.clone(),
            visualizer: EllipsoidVisualizer::new(images_dir),
        }
