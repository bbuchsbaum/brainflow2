            // Edge should be dark (outside sphere)
            assert!(edge_pixel[0] < 50, "{} slice edge should be dark", name);
            
            #[cfg(debug_assertions)]
            {
                use image::{ImageBuffer, Rgba};
                let img = ImageBuffer::<Rgba<u8>, _>::from_raw(100, 100, rendered_data)
