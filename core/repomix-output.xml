            &baseline,
            "Optimized",
            &optimized,
        );
        
        assert_eq!(comparison.baseline_ms, 20.0);
        assert_eq!(comparison.optimized_ms, 16.0);
        assert_eq!(comparison.improvement_percent, 20.0);
