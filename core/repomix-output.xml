#[tokio::main]
async fn main() {
    println!("Starting MNI brain axial slice extraction test...");
    
    // Path to MNI brain template
    let mni_path = Path::new(env!("CARGO_MANIFEST_DIR"))
        .parent().unwrap()
        .parent().unwrap()
        .join("test-data/unit/tpl-MNI152NLin2009cAsym_res-01_desc-brain_T1w.nii");
    
