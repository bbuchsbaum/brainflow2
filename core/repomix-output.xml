use render_loop::RenderLoopService;
use volmath::{DenseVolume3, NeuroSpace3, NeuroSpaceExt};
use volmath::space::{NeuroSpaceImpl, GridSpace};
use image::{ImageBuffer, Rgba};
use std::path::Path;
use std::fs;

