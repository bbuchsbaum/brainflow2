        &SliceIndex::Relative(0.0),
        &dims2,
        SliceAxis::Axial,
        &volume_data2
    ).unwrap();
    assert_eq!(result, 0);
    
    // Relative 1.0 should give last slice
    let result = api_bridge::calculate_slice_index(
        &SliceIndex::Relative(1.0),
        &dims2,
        SliceAxis::Axial,
        &volume_data2
    ).unwrap();
    assert_eq!(result, 49);
