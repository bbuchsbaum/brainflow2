    });

    it('should handle ArrayBuffer response correctly', async () => {
      const data = new Uint8Array([137, 80, 78, 71, 13, 10, 26, 10]); // PNG signature
      const arrayBuffer = data.buffer;
      mockTransport.invoke.mockResolvedValue(arrayBuffer);

