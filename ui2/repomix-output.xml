import React from 'react';

interface PanelHeaderAction {
  label: string;
  icon?: string;
  onClick: () => void;
  disabled?: boolean;
}

interface PanelHeaderProps {
  title: string;
  icon?: string;
  actions?: PanelHeaderAction[];
