        order: 0
      };
      
      eventBus.emit('layer.added', { layer });

      expect(handler1).toHaveBeenCalledWith({ layer });
      expect(handler2).toHaveBeenCalledWith({ layer });
    });

    it('should unsubscribe handlers', () => {
