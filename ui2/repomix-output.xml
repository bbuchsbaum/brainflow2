/**
 * Atlas Service - TypeScript wrapper for atlas Tauri commands
 */

import { invoke } from '@tauri-apps/api/core';
import { listen } from '@tauri-apps/api/event';
import type {
  AtlasCatalogEntry,
  AtlasConfig,
  AtlasFilter,
  AtlasLoadResult,
