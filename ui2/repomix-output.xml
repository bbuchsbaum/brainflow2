      <div className="relative">
        <input
          type="range"
          className={`${styles.sliderInput} w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer`}
          min={min}
          max={max}
          step={step}
          disabled={disabled}
          value={value}
          onChange={handleChange}
        />
      </div>
    </div>
  );
};
