}

export const LayerStatusBar: React.FC<LayerStatusBarProps> = ({
  error,
  isInitializing,
  fileLoadingStatus
}) => {
  if (error) {
    return (
      <div className="bg-red-500/20 border border-red-500/50 rounded p-3 mb-4">
